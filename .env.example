# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_SITE_URL: The canonical production URL of the site.
# Falls back to Vercel's VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL if unset.
NEXT_PUBLIC_SITE_URL="https://veggieprice.tw"

# GOOGLE_SITE_VERIFICATION: Google Search Console ownership verification token.
# Get it from Search Console → Settings → Ownership verification → HTML tag method.
# Copy only the content="..." value, e.g. "abc123XYZ"
GOOGLE_SITE_VERIFICATION=""

# MOA_FETCH_TIMEOUT_MS: Timeout for MOA Open Data API requests (default: 10000).
MOA_FETCH_TIMEOUT_MS="10000"

# DATABASE_URL: Neon serverless Postgres 連線字串，供「意見回饋」與「行為稽核」寫入使用。
# 於 Neon Console 建立專案後取得，並在 db/schema.sql 執行後即可使用。
# 未設定時：回饋送出回傳 503、行為稽核靜默略過（不影響其他功能）。
DATABASE_URL="postgres://<user>:<password>@<host>/<db>?sslmode=require"

# Cross-project telemetry (server-only; never expose via NEXT_PUBLIC_*)
# TELEMETRY_INGEST_URL="https://<admin-console-domain>/api/telemetry/ingest"
# TELEMETRY_PROJECT_KEY="veggie"
# TELEMETRY_INGEST_KEY="<same secret as the admin console TELEMETRY_INGEST_KEYS.veggie>"
